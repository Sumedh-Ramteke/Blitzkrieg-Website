# Frontend Environment Variables
# Copy this to .env.local and fill in your values

# YouTube
# YouTube Data API v3 key
VITE_YOUTUBE_API_KEY=

# Channel handle without @ (default: BlitzkriegVNIT)
VITE_YOUTUBE_HANDLE=BlitzkriegVNIT

